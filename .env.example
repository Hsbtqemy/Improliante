# Exemple de configuration locale — À COPIER en `.env` (non versionné).
#
#   cp .env.example .env       # puis renseigner les valeurs
#
# En production, ces variables sont fournies par systemd (EnvironmentFile,
# cf. deploiement/asso.service), et NON par un fichier .env.

# --- Django -----------------------------------------------------------------
# En développement : DJANGO_DEBUG=1 suffit (une clé de repli est utilisée).
# En production : DJANGO_DEBUG=0 et DJANGO_SECRET_KEY OBLIGATOIRE.
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CSRF_TRUSTED_ORIGINS=https://exemple.org

# --- Base de données PostgreSQL --------------------------------------------
DB_NAME=asso
DB_USER=asso
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Fichiers privés (documents, reçus, factures) --------------------------
# En dev, laisser tel quel : Django sert lui-même les fichiers privés.
# En production, Nginx les sert via X-Accel-Redirect (cf. deploiement/
# nginx-improliante.conf). UTILISER_X_ACCEL vaut « not DEBUG » par défaut.
# DJANGO_X_ACCEL=1
# DJANGO_X_ACCEL_PREFIXE=/media-prive/
# DJANGO_MEDIA_PRIVE_ROOT=/srv/asso/app/media_prive

# Générer une clé secrète :
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
